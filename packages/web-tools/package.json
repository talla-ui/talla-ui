{
	"name": "@talla-ui/web-tools",
	"version": "4.0.2",
	"publishConfig": {
		"tag": "latest",
		"access": "public"
	},
	"description": "Talla UI framework: web developer tools",
	"author": "Jelmer Cormont",
	"license": "MIT",
	"homepage": "https://talla-ui.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/talla-ui/talla-ui"
	},
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": "./dist/index.js"
	},
	"sideEffects": false,
	"scripts": {
		"clean": "rimraf dist",
		"prebuild": "npm run clean",
		"build": "tsc -p src",
		"postbuild": "prettier --log-level error --write \"dist/**/*.d.ts\"",
		"check-format": "prettier -l \"src/**/*.ts\"",
		"format": "prettier --write \"src/**/*.ts\""
	},
	"prettier": {
		"useTabs": true,
		"trailingComma": "all",
		"endOfLine": "lf",
		"plugins": [
			"prettier-plugin-organize-imports"
		]
	},
	"files": [
		"dist"
	],
	"peerDependencies": {
		"@talla-ui/core": "4.0.2",
		"@talla-ui/web-handler": "4.0.0-dev.105"
	},
	"devDependencies": {
		"@talla-ui/core": "file:../core",
		"@talla-ui/util": "file:../util",
		"@talla-ui/web-handler": "file:../web-handler"
	}
}
